# MOCHU-OA Docker Compose 环境变量
# 复制此文件为 .env 并修改密码

# MySQL
MYSQL_ROOT_PASSWORD=changeme

# Redis
REDIS_PASSWORD=changeme

# MinIO
MINIO_ACCESS_KEY=mochu_admin
MINIO_SECRET_KEY=changeme

# JWT
JWT_SECRET=MochuOA_V3_2_SecretKey_2026_AtLeast32Bytes!

# AES-256 数据加密密钥（必须32字节）
ENCRYPTION_AES_KEY=MochuOA_AES256_Key_32Bytes_2026!

# HMAC 签名密钥
SIGNATURE_KEY=MochuOA_Signature_Key_2026

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:80
